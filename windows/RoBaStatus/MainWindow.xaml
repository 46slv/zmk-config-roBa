<Window x:Class="RoBaStatus.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="roBa Status"
        Width="520" Height="390"
        MinWidth="460" MinHeight="370"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PanelBrush}"
        Foreground="White">
  <Window.TaskbarItemInfo>
    <TaskbarItemInfo x:Name="TaskbarInfo" Description="roBa Status" />
  </Window.TaskbarItemInfo>

  <Grid Margin="22">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <StackPanel>
        <TextBlock Text="roBa" FontSize="25" FontWeight="SemiBold" />
        <TextBlock Text="{Binding ConnectionLabel}" Foreground="{StaticResource MutedBrush}" Margin="0,3,0,0" />
      </StackPanel>
      <Button Grid.Column="1" Content="再取得" Click="Refresh_Click" VerticalAlignment="Center" />
    </Grid>

    <Grid Grid.Row="1" Margin="0,22,0,20">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="1.25*" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" Background="{StaticResource CardBrush}" CornerRadius="12" Padding="16" Margin="0,0,10,0">
        <StackPanel>
          <TextBlock Text="LAYER" Foreground="{StaticResource MutedBrush}" FontSize="12" FontWeight="Bold" />
          <TextBlock Text="{Binding LayerName}" FontSize="23" FontWeight="Bold" Margin="0,13,0,0" TextWrapping="Wrap" />
          <TextBlock Text="{Binding ActiveLayers}" Foreground="{StaticResource MutedBrush}" Margin="0,10,0,0" TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <Border Grid.Column="1" Background="{StaticResource CardBrush}" CornerRadius="12" Padding="15" Margin="0,0,10,0">
        <StackPanel>
          <TextBlock Text="RIGHT" Foreground="{StaticResource MutedBrush}" FontSize="12" FontWeight="Bold" />
          <TextBlock Text="{Binding RightBattery.Display}" FontSize="29" FontWeight="Bold" Margin="0,13,0,0" />
          <TextBlock Text="central" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0" />
        </StackPanel>
      </Border>

      <Border Grid.Column="2" Background="{StaticResource CardBrush}" CornerRadius="12" Padding="15">
        <StackPanel>
          <TextBlock Text="LEFT" Foreground="{StaticResource MutedBrush}" FontSize="12" FontWeight="Bold" />
          <TextBlock Text="{Binding LeftBattery.Display}" FontSize="29" FontWeight="Bold" Margin="0,13,0,0" />
          <TextBlock Text="peripheral" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0" />
        </StackPanel>
      </Border>
    </Grid>

    <Grid Grid.Row="2">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <StackPanel>
        <TextBlock Text="{Binding Message}" Foreground="{StaticResource MutedBrush}" TextTrimming="CharacterEllipsis" />
        <TextBlock Text="{Binding LastUpdatedLabel}" Foreground="#6F7C8B" FontSize="11" Margin="0,3,0,0" />
        <CheckBox x:Name="StartupCheckBox"
                  Content="Windowsログイン時に起動"
                  Foreground="{StaticResource MutedBrush}"
                  Margin="0,9,0,0"
                  Checked="StartupCheckBox_Changed"
                  Unchecked="StartupCheckBox_Changed" />
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal">
        <Button Content="最小化" Click="Minimize_Click" Margin="0,0,8,0" />
        <Button Content="終了" Click="Quit_Click" />
      </StackPanel>
    </Grid>
  </Grid>
</Window>
