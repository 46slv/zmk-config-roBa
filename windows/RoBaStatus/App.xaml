<Application x:Class="RoBaStatus.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
  <Application.Resources>
    <SolidColorBrush x:Key="PanelBrush" Color="#151A22" />
    <SolidColorBrush x:Key="CardBrush" Color="#202733" />
    <SolidColorBrush x:Key="MutedBrush" Color="#9BA8B8" />
    <Style TargetType="Button">
      <Setter Property="Background" Value="#2C3544" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
  </Application.Resources>
</Application>
