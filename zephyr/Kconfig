menu "roBa features"

config ROBA_ENCODER_SCROLL
    bool "roBa velocity-sensitive one-shot encoder scroll"
    default y
    depends on DT_HAS_ZMK_BEHAVIOR_ROBA_ENCODER_SCROLL_ENABLED
    select ZMK_POINTING
    help
      Replaces queued mouse-scroll press/release taps with finite wheel
      reports. Slow detents remain precise, fast consecutive detents use
      bounded acceleration, and an optional maximum-tier-only coast tail
      always terminates after a fixed report count.

config ROBA_STATUS
    bool "roBa read-only status service"
    depends on ZMK_BLE && ZMK_SPLIT_ROLE_CENTRAL
    default y if SHIELD_ROBA_R
    help
      Exposes the active ZMK layer state through a read-only encrypted BLE
      GATT characteristic for the companion Windows status application.
      No keycodes or typed content are transmitted.

config ROBA_STATUS_USB
    bool "roBa read-only USB HID status transport"
    depends on ROBA_STATUS && ZMK_USB
    default y
    help
      Adds a second vendor-defined HID interface that reports the same status
      packet over USB. It remains separate from keyboard/mouse HID and the ZMK
      Studio CDC transport.

endmenu
